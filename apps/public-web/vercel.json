{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://nexlum.site https://www.nexlum.site https://*.nexlum.site"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/inscripcion",
      "destination": "/index.html"
    },
    {
      "source": "/inscripcion/:path*",
      "destination": "/:path*"
    }
  ]
}
